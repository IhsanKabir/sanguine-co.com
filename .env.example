# ─── Supabase ────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx           # server-only, never expose

# ─── Database ────────────────────────────────────────────────
# From Supabase → Connect → Direct (or Settings → Database → Connection string).
# Use the pooler URL (port 6543) for runtime — it works for both serverless
# (Vercel) and local dev. Replace YOUR-PASSWORD with your real DB password.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Email (Brevo) ───────────────────────────────────────────
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=concierge@sanguine-co.com
BREVO_FROM_NAME=Sanguine

# ─── SMS (SSL Wireless — BD) ─────────────────────────────────
SSLWIRELESS_API_TOKEN=
SSLWIRELESS_SID=

# ─── Shipping (Pathao + Steadfast) ───────────────────────────
PATHAO_BASE_URL=https://api-hermes.pathao.com
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
PATHAO_USERNAME=
PATHAO_PASSWORD=
PATHAO_STORE_ID=

STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# ─── Sanity (CMS) ────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# ─── Cloudinary (images) ─────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Observability ───────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Floating chat (BD-essential) ────────────────────────────
# Format: country code + number, no '+' (e.g. 8801712345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Your Facebook Page username (visible in m.me/<username>)
NEXT_PUBLIC_MESSENGER_PAGE=

# ─── Cloudflare Web Analytics (free, privacy-friendly) ───────
# Get the token from Cloudflare → Analytics → Web Analytics → Add a site → JS snippet (the "token" param)
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ─── Site ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
